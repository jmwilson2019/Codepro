{
  "name": "seraphina-vscode-integration",
  "displayName": "Seraphina VSCode Integration",
  "description": "Experimental hybrid AI system combining Grok with Seraphina's Roman Wheel truth validation for code auditing.",
  "version": "0.1.0",
  "publisher": "jwc",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "seraphina.auditWithConsensus",
        "title": "Seraphina: Audit with Roman Wheel Consensus"
      },
      {
        "command": "seraphina.glyphAnalysis",
        "title": "Seraphina: Glyph Pattern Analysis"
      },
      {
        "command": "seraphina.setApiKeys",
        "title": "Seraphina: Set API Keys"
      },
      {
        "command": "seraphina.openTruthPanel",
        "title": "Seraphina: Open Truth Validation Panel"
      }
    ],
    "configuration": {
      "title": "Grok 4-Agent Auditor",
      "properties": {
        "grok4agent.apiKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "password"
          },
          "default": [],
          "maxItems": 4,
          "description": "Your 4 Grok API keys (one per agent). Stored securely in VS Code SecretStorage."
        },
        "grok4agent.defaultModel": {
          "type": "string",
          "default": "grok-4",
          "enum": [
            "grok-4",
            "grok-4.20",
            "grok-4-1-fast-reasoning"
          ],
          "description": "Default model for the agents"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "openai": "^4.66.1"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
