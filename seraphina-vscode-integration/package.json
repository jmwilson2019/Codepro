{
  "name": "seraphina-vscode-integration",
  "displayName": "Seraphina VSCode Integration",
  "description": "Hybrid AI code auditor combining Grok with Seraphina's Roman Wheel truth-validation consensus across 4 specialist agents.",
  "version": "0.2.0",
  "publisher": "jwc",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "seraphina.auditWithConsensus",
        "title": "Seraphina: Audit Current File with Roman Wheel Consensus"
      },
      {
        "command": "seraphina.glyphAnalysis",
        "title": "Seraphina: Glyph Pattern Analysis"
      },
      {
        "command": "seraphina.setApiKeys",
        "title": "Seraphina: Set Grok API Keys"
      },
      {
        "command": "seraphina.openTruthPanel",
        "title": "Seraphina: Open Truth Validation Panel"
      }
    ],
    "configuration": {
      "title": "Seraphina VSCode Integration",
      "properties": {
        "seraphina.model": {
          "type": "string",
          "default": "grok-4-1-fast-reasoning",
          "enum": [
            "grok-4",
            "grok-4.20-0309-reasoning",
            "grok-4-1-fast-reasoning"
          ],
          "description": "Grok model used by each agent."
        },
        "seraphina.maxTokensPerAgent": {
          "type": "number",
          "default": 2400,
          "description": "Max tokens per agent response."
        },
        "seraphina.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Sampling temperature for each agent."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "dependencies": {
    "openai": "^4.66.1"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
