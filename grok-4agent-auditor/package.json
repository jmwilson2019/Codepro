{
  "name": "grok-4agent-auditor",
  "displayName": "Grok 4-Agent Auditor",
  "description": "Enterprise code auditing with 4 collaborating Grok agents",
  "version": "3.3.3",
  "publisher": "SynerGroAICorp",
  "repository": {
    "type": "git",
    "url": "https://github.com/SynerGro-AI/grok-4agent-auditor.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "icon": "images/SynerGroIcon.png",
  "contributes": {
    "commands": [
      {
        "command": "grok4agent.auditCurrentFile",
        "title": "Audit Current File with 4 Grok Agents",
        "icon": "images/SynerGroIcon.png"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "grok4agent.auditCurrentFile",
          "group": "navigation",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Grok 4-Agent Auditor",
      "properties": {
        "grok4agent.apiKeys": {
          "type": "array",
          "items": { "type": "string", "format": "password" },
          "default": [],
          "maxItems": 4,
          "description": "Add your 4 Grok API keys here"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "openai": "^4.52.0"
  }
}