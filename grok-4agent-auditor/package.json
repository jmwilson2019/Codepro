{
  "name": "grok-4agent-auditor",
  "displayName": "Grok 4-Agent Auditor",
  "description": "Enterprise code auditing with 4 collaborating Grok agents — now with Roman Wheel consensus, Truth Score, and Glyph analysis.",
  "version": "3.4.3",
  "publisher": "SynerGroAICorp",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmwilson2019/Codepro.git",
    "directory": "grok-4agent-auditor"
  },
  "bugs": {
    "url": "https://github.com/jmwilson2019/Codepro/issues"
  },
  "homepage": "https://github.com/jmwilson2019/Codepro/tree/main/grok-4agent-auditor#readme",
  "qna": "https://github.com/jmwilson2019/Codepro/discussions",
  "keywords": [
    "grok",
    "xai",
    "audit",
    "code review",
    "ai",
    "agents",
    "security",
    "performance",
    "consensus",
    "truth score"
  ],
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "icon": "images/SynerGroIcon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "grok4agent.auditCurrentFile",
        "title": "Grok 4-Agent: Audit Current File",
        "icon": "images/SynerGroIcon.png"
      },
      {
        "command": "grok4agent.auditWithConsensus",
        "title": "Grok 4-Agent: Audit Current File with Roman Wheel Consensus"
      },
      {
        "command": "grok4agent.glyphAnalysis",
        "title": "Grok 4-Agent: Glyph Pattern Analysis"
      },
      {
        "command": "grok4agent.openTruthPanel",
        "title": "Grok 4-Agent: Open Truth Validation Panel"
      },
      {
        "command": "grok4agent.setApiKeys",
        "title": "Grok 4-Agent: Set API Keys (Secure)"
      },
      {
        "command": "grok4agent.reportIssue",
        "title": "Grok 4-Agent: Report an Issue / Send Feedback"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "grok4agent.auditCurrentFile",
          "group": "navigation",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Grok 4-Agent Auditor",
      "properties": {
        "grok4agent.apiKeys": {
          "type": "array",
          "items": { "type": "string", "format": "password" },
          "default": [],
          "maxItems": 4,
          "description": "Legacy: Grok API keys in settings. Prefer the secure storage flow via the 'Grok 4-Agent: Set API Keys (Secure)' command."
        },
        "grok4agent.model": {
          "type": "string",
          "default": "grok-4",
          "enum": [
            "grok-4",
            "grok-4.20-0309-reasoning",
            "grok-4-1-fast-reasoning"
          ],
          "description": "Grok model used by each agent."
        },
        "grok4agent.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Sampling temperature for the Roman Wheel consensus audit."
        },
        "grok4agent.maxTokensPerAgent": {
          "type": "number",
          "default": 2400,
          "description": "Max tokens per agent in the consensus audit."
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "openai": "^4.52.0"
  }
}
