{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      // "preLaunchTask": "npm: watch",     // Commented out - we run watch manually in terminal
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 0
      }
    }
  ]
}