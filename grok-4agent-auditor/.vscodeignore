vsc-extension-quickstart.md\n\n# Folder providing the default build configuration
.vscode/**
!.vscode/extensions.json

# Output folder - keep extension.js for packaging
# dist/**

# Node modules
**/node_modules/**

# Tests
.vscode-test/**

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Temporary files
*.tmp
*.temp

# Coverage directory used by tools like istanbul
**/coverage/**

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# parcel-bundler cache (https://parceljs.org/)
.cache

# Optional REPL history
.node_repl_history
